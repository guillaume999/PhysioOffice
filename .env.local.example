# Dev user switcher — copy this file to .env.local and fill in your credentials
# .env.local is gitignored and will never be committed
VITE_DEV_ADMIN_EMAIL=admin@example.com
VITE_DEV_ADMIN_PASSWORD=yourpassword

VITE_DEV_USER1_EMAIL=user1@example.com
VITE_DEV_USER1_PASSWORD=yourpassword1

VITE_DEV_USER2_EMAIL=user2@example.com
VITE_DEV_USER2_PASSWORD=yourpassword2
